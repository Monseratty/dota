STORAGE_DRIVER=local

# Admin panel auth. Set both on production.
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_SESSION_TTL_SECONDS=28800
ADMIN_COOKIE_SECURE=false

# Wasabi / S3 settings. Leave STORAGE_DRIVER=local until you want uploads.
S3_ENDPOINT=https://s3.eu-central-2.wasabisys.com
S3_REGION=eu-central-2
S3_BUCKET=dota12
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
S3_UPLOAD_PREFIX=raw
S3_DIRECT_UPLOAD_PREFIX=incoming
S3_PRESIGNED_URL_TTL_SECONDS=900

# Parser runtime. Defaults are tuned for small VPS instances.
CLARITY_JAVA_XMX=512m
CLARITY_JAVA_OPTS=
CLARITY_RUNNER=java
